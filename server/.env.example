# Project Quill AI - Backend Environment Configuration

# Port to run the server on (defaults to 5000)
PORT=5000

# Google Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection URI (Optional: If omitted, the server automatically defaults to local JSON file storage in server/data/db.json)
# MONGODB_URI=mongodb://localhost:27017/quill_ai
